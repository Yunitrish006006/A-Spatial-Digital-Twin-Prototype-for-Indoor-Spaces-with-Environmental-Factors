{
  "schema_version": "room-design-v1",
  "room": {
    "name": "custom_room",
    "description": "single rectangular room; replace dimensions and baseline values before use",
    "width_m": 6.0,
    "length_m": 4.0,
    "height_m": 3.0,
    "base_temperature_c": 29.0,
    "base_humidity_pct": 67.0,
    "base_illuminance_lux": 90.0
  },
  "grid_resolution": {
    "nx": 16,
    "ny": 12,
    "nz": 6
  },
  "coordinate_system": {
    "unit": "m",
    "origin": "floor southwest corner",
    "x_axis": "room width direction",
    "y_axis": "room length direction",
    "z_axis": "height from floor"
  },
  "environment": {
    "outdoor_temperature_c": 33.0,
    "outdoor_humidity_pct": 74.0,
    "sunlight_illuminance_lux": 32000.0,
    "daylight_factor": 0.95
  },
  "sensors": [
    { "name": "floor_sw", "position": { "x": 0.0, "y": 0.0, "z": 0.0 } },
    { "name": "floor_se", "position": { "x": 6.0, "y": 0.0, "z": 0.0 } },
    { "name": "floor_nw", "position": { "x": 0.0, "y": 4.0, "z": 0.0 } },
    { "name": "floor_ne", "position": { "x": 6.0, "y": 4.0, "z": 0.0 } },
    { "name": "ceiling_sw", "position": { "x": 0.0, "y": 0.0, "z": 3.0 } },
    { "name": "ceiling_se", "position": { "x": 6.0, "y": 0.0, "z": 3.0 } },
    { "name": "ceiling_nw", "position": { "x": 0.0, "y": 4.0, "z": 3.0 } },
